# Google Drive API Settings
# To enable real Google Drive upload:
# 1. Share a Google Drive folder with your service account email (Editor permissions)
# 2. Fill in the credentials below
# 3. Rename this file to `.env.local` (or copy these to a new `.env.local` file)

GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"

# Paste your private key exactly as it appears in the JSON key file, including the quotes and escaped newlines (\n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The 33-character folder ID from the Google Drive shared folder URL
GOOGLE_DRIVE_PARENT_FOLDER_ID="your-google-drive-shared-folder-id"

# (Optional) DeepSeek API configuration
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_ANALYSIS_MODEL="deepseek-chat"

# Google OAuth2 Credentials (Used for Google Drive Sync)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"

